# 复制这个文件为 .env 并填入真实的API Key
# LLM和Embedding统一使用通义千问（DashScope），只需一个Key

DASHSCOPE_API_KEY=sk-xxxx

# 以下保持默认即可，无需修改
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen3-max-2026-01-23
# EMB_MODEL=text-embedding-v3
# EMB_DIM=1024
# RAG_TOP_K=10
# RAG_GRAPH_HOP=1

# small-to-big 分块（01-vector-engine）
# CHUNK_SMALL=300
# CHUNK_BIG=1800
# CHUNK_OVERLAP=60

# re-rank（默认开，会调用 DashScope gte-rerank；无 API Key 时自动降级）
# RAG_RERANK_ENABLED=true
# RAG_RERANK_MODEL=gte-rerank
# RAG_RERANK_TOP_BEFORE=50

# HyDE 假设文档嵌入（默认关，评估证明有效后再开）
# RAG_HYDE_ENABLED=false
# HYDE_LLM_MODEL=qwen-turbo   # HyDE 生成假设答案用轻量模型，与主问答 LLM_MODEL 分开计费

# 四层记忆（03-memory，默认开）
# MEMORY_ENABLED=true           # 整体开关；false 时 user_id 参数无效，退化为现状
# SUMMARY_TRIGGER_TURNS=6       # 超过此轮数触发近期摘要（单位：轮，1轮=1问+1答）
# PROFILE_ASYNC=true            # 实体抽取是否异步（关闭后同步写库，主要用于调试）

# 评估闭环（04-eval-loop）
# EVAL_GOLDEN_PATH=eval/golden_set.jsonl  # 金标集路径
# SELFCHECK_SAMPLES=5           # SelfCheckGPT 每题采样次数
# COVE_ENABLED=true             # CoVe 在线纠错（关闭后退化为旧 Critic）
# RAGAS_JUDGE_MODEL=qwen3-max-2026-01-23  # RAGAS judge LLM

# HITL 审批接口鉴权（06-mcp-loop-guard）
# HITL_API_KEY=your-secret-key  # 必须设置，否则 /agent/pending 和 /agent/approve 返回 503
#                                # 前端请求时在 Header 携带 X-Hitl-Key: <key>
