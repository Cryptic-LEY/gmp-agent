{
  "name": "gmp-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbo --hostname 0.0.0.0 --port 3000",
    "dev:api": "cd ../gmp-api && uvicorn main:app --host 0.0.0.0 --port 8001",
    "dev:full": "concurrently --kill-others -n \"Web,API\" -c \"cyan,green\" \"npm run dev\" \"npm run dev:api\"",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 3000",
    "start:prod": "next start --hostname 0.0.0.0 --port 3000",
    "team-sync": "node team-sync-server/server.cjs",
    "dev:team-sync": "node team-sync-server/server.cjs",
    "db:seed-admin": "node scripts/seed-admin.js",
    "db:mysql:schema": "node scripts/migrate-sqlite-to-mysql.js --create-schema --skip-data",
    "db:mysql:migrate": "node scripts/migrate-sqlite-to-mysql.js --create-schema"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@socket.io/redis-adapter": "^8.3.0",
    "@types/nodemailer": "^8.0.1",
    "ai": "^6.0.168",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "docx": "^9.6.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "echarts": "^6.1.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^1.9.0",
    "msedge-tts": "^2.0.5",
    "mysql2": "^3.22.3",
    "next": "16.2.4",
    "nodemailer": "^9.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "redis": "^6.0.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "three": "^0.184.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
